{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@engine/*": ["src/engine/*"],
      "@data/*": ["src/data/*"],
      "@entities/*": ["src/entities/*"],
      "@tasks/*": ["src/tasks/*"],
      "@generation/*": ["src/generation/*"],
      "@rendering/*": ["src/rendering/*"],
      "@ui/*": ["src/ui/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
